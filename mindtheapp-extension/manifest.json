{
  "manifest_version": 3,
  "name": "Mind the App",
  "version": "0.1.0",
  "description": "AI-powered gap analysis & resume generation companion for jobseek.fyi",
  "action": {
    "default_title": "Mind the App"
  },
  "permissions": ["sidePanel", "storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.jobseek.fyi/*",
    "https://jobseek.fyi/*",
    "*://greenhouse.io/*",
    "*://*.greenhouse.io/*",
    "*://boards.greenhouse.io/*",
    "*://job-boards.greenhouse.io/*",
    "*://jobs.lever.co/*",
    "*://app.ashbyhq.com/*",
    "*://jobs.ashbyhq.com/*",
    "*://*.ashbyhq.com/*",
    "*://linkedin.com/*",
    "*://*.linkedin.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://boards.greenhouse.io/*",
        "*://job-boards.greenhouse.io/*",
        "*://*.greenhouse.io/*",
        "*://jobs.lever.co/*",
        "*://app.ashbyhq.com/*",
        "*://jobs.ashbyhq.com/*",
        "*://*.ashbyhq.com/*",
        "*://*.linkedin.com/jobs/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.jobseek.fyi/*", "https://jobseek.fyi/*"],
      "js": ["content/auth-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": ["https://*.jobseek.fyi/*", "https://jobseek.fyi/*"]
  }
}
